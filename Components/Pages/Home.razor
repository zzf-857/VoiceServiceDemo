@page "/"

@inject SettingsService SettingsService
@inject NavigationManager Navigation

<div class="page-header">
    <h2>选择语音生成厂商</h2>
    <p>请选择一个 TTS 提供商以初始化语音生成环境。</p>
</div>

<div class="vendor-grid">
    @foreach (var vendor in VendorRegistry.All)
    {
        var v = vendor;
        var hasKey = !string.IsNullOrWhiteSpace(SettingsService.GetApiKey(v.Id));
        var iconPath = GetVendorIconPath(v.Id);

        <div class="vendor-card" @onclick="() => OpenVendor(v.Id)">
            <div class="vendor-card-header">
                <div class="vendor-icon-box">
                    @if (!string.IsNullOrEmpty(iconPath))
                    {
                        <img class="vendor-brand-icon" src="@iconPath" alt="" />
                    }
                    else
                    {
                        @((MarkupString)GetVendorSvg(v.IconName))
                    }
                </div>
                <h3>@v.Name</h3>
            </div>
            <p>@v.Description</p>
            <div class="card-footer">
                @if (hasKey)
                {
                    <span class="status-badge configured">● 已配置</span>
                    <button class="btn btn-primary" @onclick:stopPropagation="true" @onclick="() => OpenVendor(v.Id)">进入工作区</button>
                }
                else
                {
                    <span class="status-badge unconfigured">○ 未配置</span>
                    <button class="btn btn-secondary" @onclick:stopPropagation="true" @onclick="() => GoToSettings(v.Id)">配置 API Key</button>
                }
            </div>
        </div>
    }
</div>

@code {
    private void OpenVendor(string vendorId)
    {
        var hasKey = !string.IsNullOrWhiteSpace(SettingsService.GetApiKey(vendorId));
        if (hasKey)
            Navigation.NavigateTo($"/workspace/{vendorId}");
        else
            GoToSettings(vendorId);
    }

    private void GoToSettings(string vendorId)
    {
        Navigation.NavigateTo($"/settings?focus={vendorId}");
    }

    private static string GetVendorIconPath(string vendorId) => vendorId switch
    {
        "huoshan" => "assets/vendor-icons/huoshan.png",
        "tencent" => "assets/vendor-icons/tencent.ico",
        "aliyun" => "assets/vendor-icons/aliyun.ico",
        "xiaomi_mimo" => "assets/vendor-icons/xiaomi_mimo.png",
        "minimax" => "assets/vendor-icons/minimax.ico",
        "fish_audio" => "assets/vendor-icons/fish_audio.svg",
        "deepgram" => "assets/vendor-icons/deepgram.svg",
        "elevenlabs" => "assets/vendor-icons/elevenlabs.svg",
        "baidu" => "assets/vendor-icons/baidu.ico",
        "azure" => "assets/vendor-icons/azure.ico",
        "google" => "assets/vendor-icons/google.ico",
        "openai" => "assets/vendor-icons/openai.svg",
        "cartesia" => "assets/vendor-icons/cartesia.svg",
        _ => ""
    };

    private string GetVendorSvg(string iconName) => iconName switch
    {
        "flame" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z'/></svg>",
        "cloud" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z'/></svg>",
        "scan-search" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M3 7V5a2 2 0 0 1 2-2h2'/><path d='M17 3h2a2 2 0 0 1 2 2v2'/><path d='M21 17v2a2 2 0 0 1-2 2h-2'/><path d='M7 21H5a2 2 0 0 1-2-2v-2'/><circle cx='12' cy='12' r='3'/><path d='m16 16-1.9-1.9'/></svg>",
        "layout-template" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect width='18' height='7' x='3' y='3' rx='1'/><rect width='9' height='7' x='3' y='14' rx='1'/><rect width='5' height='7' x='16' y='14' rx='1'/></svg>",
        "globe" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><path d='M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20'/><path d='M2 12h20'/></svg>",
        "bot" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M12 8V4H8'/><rect width='16' height='12' x='4' y='8' rx='2'/><path d='M2 14h2'/><path d='M20 14h2'/><path d='M15 13v2'/><path d='M9 13v2'/></svg>",
        "sparkles" => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M9.9 10.8 8 16l-1.9-5.2L1 9l5.1-1.8L8 2l1.9 5.2L15 9l-5.1 1.8Z'/><path d='m19 15 1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3Z'/></svg>",
        _ => "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z'/></svg>"
    };
}
