    private string GetFriendlyErrorMessage(string message)
    {
        var lower = message.ToLowerInvariant();
        if (lower.Contains("api key") || message.Contains("鉴权") || lower.Contains("unauthorized") || lower.Contains("forbidden"))
            return "凭证可能无效或权限不足。请回到系统设置检查该厂商的 API Key，并使用“测试连通”确认。";
        if (lower.Contains("timeout") || message.Contains("连接失败") || message.Contains("网络"))
            return "网络请求没有完成。请检查网络连接、代理设置，或稍后重试。";
        if (message.Contains("格式") || lower.Contains("format"))
            return "当前输入格式不符合厂商要求。请检查凭证格式、音色 ID 或文本内容。";
        if (message.Contains("额度") || lower.Contains("quota") || lower.Contains("limit"))
            return "服务额度或频率可能受限。请检查厂商控制台的额度、计费或调用限制。";
        if (message.Contains("文件") || lower.Contains("file"))
            return "音频文件处理失败。请检查输出目录是否存在、是否有写入权限。";
        return "操作没有完成。请检查配置、网络或厂商服务状态后重试。";
    }

    private void ShowStatus(string message, string kind = "info")
    {
        _statusCts?.Cancel();
        _statusCts = new System.Threading.CancellationTokenSource();
        var token = _statusCts.Token;

        _statusMessage = message;
        _statusKind = kind;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(2400, token);
                await InvokeAsync(() =>
                {
                    if (!token.IsCancellationRequested)
                    {
                        _statusMessage = null;
                        StateHasChanged();
                    }
                });
            }
            catch (TaskCanceledException) { }
        });
    }

    public void Dispose()
    {
        _statusCts?.Cancel();
        _copyResetCts?.Cancel();
        _dotNetRef?.Dispose();
    }
}
