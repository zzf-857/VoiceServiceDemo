    protected override async Task OnParametersSetAsync()
    {
        _vendor = VendorRegistry.GetById(VendorId);
        if (_vendor != null)
        {
            _speed = _vendor.SpeedDef.Default;
            _volume = _vendor.VolumeDef.Default;
            _inputFormat = TtsInputFormat.PlainText;
            _selectedStyle = "";
            _selectedEmotion = "";
            _emotionIntensity = TencentEmotionPolicy.DefaultIntensity;
            _outputFormat = _vendor.Capabilities.SupportedOutputFormats.FirstOrDefault() ?? "mp3";
            _styleDegree = 1.0;
            _ssmlText = "";

            // 支持在线获取的厂商：尝试从本地缓存加载
            if (_vendor.SupportsVoiceFetch)
            {
                _allVoices = new();
                _selectedVoiceId = "";
                _selectedVoiceName = "";
                _voiceListStatus = "";
                var loadedVoices = false;

                try
                {
                    var cacheDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "VoiceOps", "Cache");
                    var cacheFile = Path.Combine(cacheDir, $"voices_{_vendor.Id}.json");
                    if (File.Exists(cacheFile))
                    {
                        var json = await File.ReadAllTextAsync(cacheFile);
                        var cached = System.Text.Json.JsonSerializer.Deserialize<List<VoiceOption>>(json);
                        if (cached != null && cached.Any())
                        {
                            ApplyVoiceList(cached, $"使用本地缓存音色库，更新时间 {File.GetLastWriteTime(cacheFile):yy-MM-dd HH:mm}");
                            loadedVoices = true;
                        }
                    }
                }
                catch { }

                if (!loadedVoices && _vendor.Id == "aliyun")
                {
                    var localVoices = await TtsService.FetchVoicesAsync(_vendor.Id);
                    if (localVoices.Any())
                    {
                        ApplyVoiceList(localVoices, "使用本地预置音色库");
                        loadedVoices = true;
                    }
                }

                if (!loadedVoices && _vendor.DefaultVoices.Any())
                {
                    ApplyVoiceList(_vendor.DefaultVoices.ToList(), "使用内置推荐音色，可刷新获取全量音色库");
                }
            }
            else
            {
                ApplyVoiceList(_vendor.DefaultVoices.ToList(), "使用内置音色列表");
            }
            _selectedModelId = _vendor.DefaultModels.FirstOrDefault()?.Id ?? "";
            EnsureValidOutputFormat();
        }
    }

    private void ApplyVoiceList(List<VoiceOption> voices, string status)
    {
        _allVoices = voices;
        _allCategories = _allVoices.SelectMany(v => v.Categories).Where(c => !string.IsNullOrWhiteSpace(c)).Distinct().ToList();
        _voiceListStatus = status;
        ResetVoicePage();
        EnsureSelectedVoice();
    }

    private void EnsureSelectedVoice()
    {
        if (!_allVoices.Any())
        {
            _selectedVoiceId = "";
            _selectedVoiceName = "";
            return;
        }

        if (!_allVoices.Any(v => v.Id == _selectedVoiceId && v.Name == _selectedVoiceName))
        {
            SelectVoice(_allVoices.First());
        }
    }

    private async Task FetchVoices()
    {
        if (_vendor == null) return;
        _isFetchingVoices = true;
        _errorMessage = null;
        StateHasChanged();

        var fetched = await TtsService.FetchVoicesAsync(_vendor.Id);
        if (fetched.Any())
        {
            ApplyVoiceList(fetched, $"已刷新全量音色库，更新时间 {DateTime.Now:yy-MM-dd HH:mm}");

            // 保存到本地缓存
            try
            {
                var cacheDir = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), "VoiceOps", "Cache");
                if (!Directory.Exists(cacheDir)) Directory.CreateDirectory(cacheDir);
                var cacheFile = Path.Combine(cacheDir, $"voices_{_vendor.Id}.json");
                var json = System.Text.Json.JsonSerializer.Serialize(_allVoices);
                await File.WriteAllTextAsync(cacheFile, json);
            }
            catch { }

            ShowStatus($"已加载 {_allVoices.Count} 个音色", "success");
        }
        else
        {
            _errorMessage = "未能获取到任何在线音色。请检查该厂商凭证是否填写并且有有效权限。";
            ShowStatus("音色库刷新失败", "error");
        }

        _isFetchingVoices = false;
        StateHasChanged();
    }

