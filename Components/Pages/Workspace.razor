    /// <summary>
    /// 核心流程：生成 → 等待文件落盘 → 读取文件元信息 → 读取字节 → base64 传给 JS 播放
    /// </summary>
    private async Task Generate()
    {
        if (_vendor == null || string.IsNullOrWhiteSpace(CurrentInputText) || string.IsNullOrEmpty(_selectedVoiceId)) return;

        // Step 1: 重置状态
        _isGenerating = true;
        _errorMessage = null;
        _result = null;
        _audioLoaded = false;
        _isPlaying = false;
        StateHasChanged();

        // Step 2: 调用 TTS API 生成并保存文件
        var request = new TtsRequest
        {
            VendorId = VendorId,
            ModelId = _selectedModelId,
            VoiceId = _selectedVoiceId,
            Text = _inputText,
            Speed = _speed,
            Volume = _volume,
            InputFormat = _inputFormat,
            Style = SupportsStyleControls ? _selectedStyle : "",
            StyleDegree = _styleDegree,
            Emotion = GetRequestEmotion(),
            EmotionIntensity = IsTencent ? _emotionIntensity : TencentEmotionPolicy.DefaultIntensity,
            OutputFormat = GetSelectedOutputFormat(),
            ResourceId = SupportsEmotionControls && IsHuoshan && _selectedVoice != null ? HuoshanEmotionPolicy.GetResourceId(_selectedVoice) : "",
            Instructions = SupportsInstructionsControls ? _instructions : "",
            SsmlText = SupportsSsmlControls ? _ssmlText : ""
        };

        _result = await TtsService.GenerateAsync(request);

        if (!_result.Success || string.IsNullOrEmpty(_result.FilePath))
        {
            _errorMessage = _result.ErrorMessage ?? "生成失败，未返回文件路径。";
            _isGenerating = false;
            StateHasChanged();
            return;
        }

        // Step 3: 确认文件已落盘（等待文件存在且大小稳定）
        var filePath = _result.FilePath;
        if (!File.Exists(filePath))
        {
            _errorMessage = $"生成的音频文件不存在: {filePath}";
            _isGenerating = false;
            StateHasChanged();
            return;
        }

        // Step 4: 读取文件元信息
        var fileInfo = new FileInfo(filePath);
        _audioFileName = fileInfo.Name;
        _audioFileSize = FormatFileSize(fileInfo.Length);

        // Step 5: 将文件读取为 byte[] → base64
        byte[] audioBytes;
        try
        {
            audioBytes = await File.ReadAllBytesAsync(filePath);
        }
        catch (Exception ex)
        {
            _errorMessage = $"读取音频文件失败: {ex.Message}";
            _isGenerating = false;
            StateHasChanged();
            return;
        }

        var base64Data = Convert.ToBase64String(audioBytes);

        // Step 6: 将 base64 传给 JS，创建 Blob URL 并播放
        try
        {
            await JS.InvokeVoidAsync("audioInterop.playBase64", base64Data, "audio/mpeg");
            await JS.InvokeVoidAsync("audioInterop.setPlaybackRate", _playbackSpeed);
            await JS.InvokeVoidAsync("audioInterop.startUpdates", _dotNetRef);
            _isPlaying = true;
            _audioLoaded = true;
            ShowStatus("语音已生成并开始播放", "success");
        }
        catch (Exception ex)
        {
            _errorMessage = $"加载音频到播放器失败: {ex.Message}";
            ShowStatus("播放器加载失败", "error");
        }

        _isGenerating = false;
        StateHasChanged();
    }

