@page "/workspace/{VendorId}"
@using System.IO
@using System.Net.Http
@using VoiceServiceDemo.Services.Providers

@inject TtsService TtsService
@inject SettingsService SettingsService
@inject IJSRuntime JS

<style>
    .main-content {
        overflow-y: auto !important;
        overflow-x: hidden !important;
        padding: clamp(12px, 2vh, 24px) clamp(16px, 4vw, 32px) !important;
        gap: 0 !important;
    }
</style>

<div class="workspace-layout">
    <div class="workspace-topbar">
        <div class="page-header workspace-title">
            <h2>@(_vendor?.Name ?? "未知厂商") — 语音生成与测试</h2>
            <p>@(_vendor?.Description ?? "")</p>
        </div>

        @if (_vendor != null)
        {
            <div class="workspace-actions">
                <div class="form-group model-picker">
                    <label>模型版本</label>
                    <div class="select-wrapper">
                        <select class="form-select" value="@_selectedModelId" @onchange="OnModelChanged">
                            @foreach (var m in _vendor.DefaultModels)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>
                </div>

                @if (_vendor.SupportsVoiceFetch)
                {
                    <button class="btn btn-outline" @onclick="FetchVoices" disabled="@_isFetchingVoices">
                        @if (_isFetchingVoices)
                        {
                            <span class="spinner" style="width:14px;height:14px;border-width:2px;"></span>
                            <span>获取中…</span>
                        }
                        else
                        {
                            <span>刷新音色库</span>
                        }
                    </button>
                }

            </div>
        }
    </div>

    @if (_vendor == null)
    {
        <div class="error-msg">找不到该厂商的配置信息。</div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_vendor.DocumentationUrl) || _vendor.ImportantLinks.Any())
        {
            <div class="important-link-strip">
                <span class="important-link-label">关键链接</span>
                <div class="important-link-list">
                    @foreach (var link in GetVendorLinks(_vendor))
                    {
                        <a href="@link.Url" target="_blank" class="btn btn-outline important-link" title="@link.Description">
                            <svg style="width:15px;height:15px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                            <span>@link.Label</span>
                        </a>
                    }
                </div>
            </div>
        }

        @if (_vendor.Id == "aliyun")
        {
            <div class="vendor-note">
                阿里云暂不支持 API 动态获取音色，当前数据来自本地预置文件。
                <a href="https://bailian.console.aliyun.com/cn-beijing?tab=model#/efm/model_experience_center/voice?currentTab=voiceTts"
                   target="_blank">前往控制台手动获取</a>
            </div>
        }

        <div class="workspace-main-grid">
        <div class="voice-main-column">
        <section class="voice-stage">
            <div class="section-heading voice-stage-heading">
                <div>
                    <span class="eyebrow">Voice Library</span>
                    <h3>选择音色</h3>
                    <p>固定分页浏览，试听后直接在右侧生成测试语音。</p>
                </div>
                <div class="voice-stage-stats">
                    <span class="voice-count">
                        匹配 <strong>@FilteredVoiceCount</strong> / @_allVoices.Count
                    </span>
                    @if (FilteredVoiceCount > VoicePageSize)
                    {
                        <span class="voice-page-pill">@VoiceRangeLabel</span>
                    }
                </div>
            </div>

            @if (_allVoices.Any())
            {
                <div class="voice-toolbar">
                    <input class="form-input voice-search" type="text" placeholder="搜索音色名称或 ID…" value="@_searchText" @oninput="OnVoiceSearchChanged" />
                    @if (!string.IsNullOrEmpty(_voiceListStatus))
                    {
                        <span class="voice-source-note">@_voiceListStatus</span>
                    }
                </div>

                <div class="voice-filter-panel">
                    <div class="filter-strip category-filter-strip">
                        @foreach (var cat in _allCategories)
                        {
                            <button class="@($"filter-chip {(_filterCategory == cat ? "active" : "")}")" @onclick="@(() => ToggleCategoryFilter(cat))">@cat</button>
                        }
                    </div>
                    <div class="gender-filter-strip">
                        <button class="@($"filter-chip {(_filterGender == "" ? "active" : "")}")" @onclick="@(() => SetGenderFilter(""))">全部</button>
                        <button class="@($"filter-chip {(_filterGender == "男" ? "active" : "")}")" @onclick="@(() => SetGenderFilter("男"))">男声</button>
                        <button class="@($"filter-chip {(_filterGender == "女" ? "active" : "")}")" @onclick="@(() => SetGenderFilter("女"))">女声</button>
                        @if (HasActiveVoiceFilters)
                        {
                            <button class="filter-chip filter-clear" @onclick="ClearVoiceFilters">清空筛选</button>
                        }
                    </div>
                </div>

                <div class="voice-card-grid">
                    @foreach (var v in PagedVoices)
                    {
                        <div class="@($"voice-card {(_selectedVoiceId == v.Id && _selectedVoiceName == v.Name ? "selected" : "")}")" @onclick="@(() => SelectVoice(v))">
                            <div class="voice-card-chrome">
                                <span class="@($"voice-avatar {(v.Gender == "女" ? "female" : "male")}")">@(v.Gender == "女" ? "女" : "男")</span>
                                @if (_selectedVoiceId == v.Id && _selectedVoiceName == v.Name)
                                {
                                    <span class="selected-badge">已选</span>
                                }
                                <div class="voice-card-actions">
                                @if (!string.IsNullOrEmpty(v.SampleUrl))
                                {
                                    <button class="voice-demo-btn" title="试听" disabled="@(_loadingDemoVoiceId == v.Id)" @onclick="@(e => ToggleDemoAudio(v))" @onclick:stopPropagation="true">
                                        @if (_loadingDemoVoiceId == v.Id)
                                        {
                                            <span class="spinner voice-demo-spinner"></span>
                                        }
                                        else if (_playingDemoVoiceId == v.Id)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:12px; height:12px;"><rect x="6" y="4" width="4" height="16"></rect><rect x="14" y="4" width="4" height="16"></rect></svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width:12px; height:12px; margin-left: 2px;"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                        }
                                    </button>
                                }
                                <button class="voice-copy-btn @(_copiedVoiceId == v.Id ? "copied" : "")" title="复制音色ID" @onclick="@(e => CopyVoiceId(v.Id))" @onclick:stopPropagation="true">
                                    @if (_copiedVoiceId == v.Id)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px; height:12px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px; height:12px;"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                    }
                                </button>
                                </div>
                            </div>
                            <div class="voice-card-info">
                                <span class="voice-card-name" title="@v.Name">@v.Name</span>
                                <span class="voice-card-meta">@FormatVoiceMeta(v)</span>
                            </div>
                            <div class="voice-card-tags">
                                @foreach (var c in HuoshanEmotionPolicy.GetDisplayTags(v))
                                {
                                    <span class="voice-tag">@c</span>
                                }
                            </div>
                        </div>
                    }
                    @if (!FilteredVoices.Any())
                    {
                        <div class="empty-state">没有找到匹配的音色</div>
                    }
                    else
                    {
                        @for (var i = 0; i < EmptyVoiceSlots; i++)
                        {
                            <div class="voice-card voice-card-placeholder" aria-hidden="true"></div>
                        }
                    }
                </div>

                @if (FilteredVoiceCount > VoicePageSize)
                {
                    <div class="voice-pagination">
                        <span>每页 36 个音色</span>
                        <div class="pagination-buttons">
                            <button class="btn btn-outline" @onclick="PreviousVoicePage" disabled="@(_voicePageIndex == 0)">上一页</button>
                            <span>@(_voicePageIndex + 1) / @VoiceTotalPages</span>
                            <button class="btn btn-outline" @onclick="NextVoicePage" disabled="@(_voicePageIndex >= VoiceTotalPages - 1)">下一页</button>
                        </div>
                    </div>
                }

                <audio id="demoAudioPlayer" style="display:none;" />
            }
            else if (!_isFetchingVoices && _vendor.SupportsVoiceFetch)
            {
                <div class="empty-state">点击上方“刷新音色库”加载音色列表</div>
            }
        </section>
        </div>

        <aside class="generation-sidebar">
        <section class="generation-panel">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Control Panel</span>
                    <h3>生成设置</h3>
                </div>
            </div>

            @if (_selectedVoice != null)
            {
                <div class="voice-detail-bar">
                    <div class="selected-voice-summary">
                        <span>当前音色</span>
                        <strong title="@_selectedVoice.Name">@_selectedVoice.Name</strong>
                        <small>@_selectedVoice.Gender · @_selectedVoice.Age</small>
                    </div>
                </div>
            }

            @if (SupportsExpressionControls)
            {
                <div class="expression-panel">
                    <div class="expression-header">
                        <span>表达方式</span>
                        <small>@ExpressionHint</small>
                    </div>

                    @if (SupportsSsmlControls || SupportsStyleControls)
                    {
                        @if (SupportsSsmlControls)
                        {
                            <div class="segmented-control">
                                <button class="@($"filter-chip {(_inputFormat == TtsInputFormat.PlainText ? "active" : "")}")"
                                        @onclick="@(() => SetInputFormat(TtsInputFormat.PlainText))">
                                    普通文本
                                </button>
                                <button class="@($"filter-chip {(_inputFormat == TtsInputFormat.Ssml ? "active" : "")}")"
                                        @onclick="@(() => SetInputFormat(TtsInputFormat.Ssml))">
                                    SSML
                                </button>
                            </div>
                        }

                        @if (SupportsStyleControls && _inputFormat == TtsInputFormat.PlainText)
                        {
                            <div class="emotion-row">
                                <span>风格</span>
                                @foreach (var style in AzureStyleOptions)
                                {
                                    <button class="@($"filter-chip {(_selectedStyle == style.Id ? "active" : "")}")"
                                            @onclick="@(() => _selectedStyle = style.Id)">
                                        @style.Name
                                    </button>
                                }
                            </div>

                            @if (SupportsStyleDegreeControls && !string.IsNullOrEmpty(_selectedStyle))
                            {
                                <div class="slider-group compact-slider">
                                    <div class="slider-header">
                                        <span class="slider-label">风格强度</span>
                                        <span class="slider-value">@_styleDegree.ToString("0.0")</span>
                                    </div>
                                    <input type="range" class="win-slider"
                                           min="0.5"
                                           max="2.0"
                                           step="0.1"
                                           @bind="_styleDegree"
                                           @bind:event="oninput" />
                                </div>
                            }
                        }
                    }

                    @if (SupportsEmotionControls && HasHuoshanEmotionControls)
                    {
                        <div class="emotion-row">
                            <span>语气</span>
                            @foreach (var emotion in HuoshanEmotionOptions)
                            {
                                <button class="@($"filter-chip {(_selectedEmotion == emotion.Id ? "active" : "")}")"
                                        @onclick="@(() => _selectedEmotion = emotion.Id)">
                                    @emotion.Name
                                </button>
                            }
                        </div>
                    }

                    @if (SupportsEmotionControls && HasTencentEmotionControls)
                    {
                        <div class="emotion-row">
                            <span>语气</span>
                            @foreach (var emotion in TencentEmotionOptions)
                            {
                                <button class="@($"filter-chip {(_selectedEmotion == emotion.Id ? "active" : "")}")"
                                        @onclick="@(() => _selectedEmotion = emotion.Id)">
                                    @emotion.Name
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(TencentEmotionPolicy.ToRequestEmotion(_selectedEmotion)))
                        {
                            <div class="slider-group compact-slider">
                                <div class="slider-header">
                                    <span class="slider-label">情感强度</span>
                                    <span class="slider-value">@_emotionIntensity</span>
                                </div>
                                <input type="range" class="win-slider"
                                       min="@TencentEmotionPolicy.MinIntensity"
                                       max="@TencentEmotionPolicy.MaxIntensity"
                                       step="1"
                                       @bind="_emotionIntensity"
                                       @bind:event="oninput" />
                            </div>
                        }
                    }

                    @if (SupportsEmotionControls && IsCartesia)
                    {
                        <div class="emotion-row">
                            <span>语气</span>
                            @foreach (var emotion in CartesiaEmotionOptions)
                            {
                                <button class="@($"filter-chip {(_selectedEmotion == emotion.Id ? "active" : "")}")"
                                        @onclick="@(() => _selectedEmotion = emotion.Id)">
                                    @emotion.Name
                                </button>
                            }
                        </div>
                    }

                    @if (SupportsInstructionsControls)
                    {
                        <div class="form-group expression-instructions">
                            <label class="field-caption">朗读指导</label>
                            <textarea class="text-area generation-text"
                                      placeholder="例如：用温柔但专业的语气朗读。"
                                      @bind="_instructions"></textarea>
                        </div>
                    }
                </div>
            }

            @if (SupportsOutputFormatControls)
            {
                <div class="emotion-row output-format-row">
                    <span>输出格式</span>
                    @foreach (var format in OutputFormatOptions)
                    {
                        <button class="@($"filter-chip {(_outputFormat == format ? "active" : "")}")"
                                @onclick="@(() => _outputFormat = format)">
                            @GetOutputFormatLabel(format)
                        </button>
                    }
                </div>
            }

            <div class="voice-sliders">
                @if (_vendor.SpeedDef.IsSupported)
                {
                    <div class="slider-group">
                        <div class="slider-header">
                            <span class="slider-label">语速</span>
                            <span class="slider-value">@_speed</span>
                        </div>
                        <input type="range" class="win-slider"
                               min="@_vendor.SpeedDef.Min"
                               max="@_vendor.SpeedDef.Max"
                               step="@_vendor.SpeedDef.Step"
                               @bind="_speed"
                               @bind:event="oninput" />
                    </div>
                }

                @if (_vendor.VolumeDef.IsSupported)
                {
                    <div class="slider-group">
                        <div class="slider-header">
                            <span class="slider-label">音量</span>
                            <span class="slider-value">@_volume</span>
                        </div>
                        <input type="range" class="win-slider"
                               min="@_vendor.VolumeDef.Min"
                               max="@_vendor.VolumeDef.Max"
                               step="@_vendor.VolumeDef.Step"
                               @bind="_volume"
                               @bind:event="oninput" />
                    </div>
                }
            </div>

            <div class="form-group">
                <label class="field-caption">@InputFieldLabel</label>
                @if (SupportsSsmlControls && _inputFormat == TtsInputFormat.Ssml)
                {
                    <textarea class="text-area generation-text" placeholder="输入完整 SSML，例如 <speak>...</speak>" @bind="_ssmlText"></textarea>
                }
                else
                {
                    <textarea class="text-area generation-text" placeholder="输入要转换成语音的测试文本…" @bind="_inputText"></textarea>
                }
            </div>

            <div class="@($"generation-readiness {(CanGenerate ? "ready" : "blocked")}")">
                <span>@GenerateReadinessMessage</span>
                <span>@InputTextLength 字</span>
            </div>

            <div class="actions-bar">
                <button class="btn btn-outline" @onclick="ClearText" disabled="@_isGenerating">清空</button>
                <button class="btn btn-primary" @onclick="Generate" disabled="@(!CanGenerate)" title="@GenerateReadinessMessage">
                    @if (_isGenerating)
                    {
                        <span class="spinner" style="width:16px;height:16px;border-width:2px;"></span>
                        <span>生成中…</span>
                    }
                    else
                    {
                        <svg style="width:16px;height:16px;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                        <span>生成语音</span>
                    }
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                var friendlyError = GetFriendlyErrorMessage(_errorMessage);
                <div class="error-msg">
                    <div>@friendlyError</div>
                    @if (!string.Equals(friendlyError, _errorMessage, StringComparison.Ordinal))
                    {
                        <details class="error-details">
                            <summary>查看技术详情</summary>
                            <pre>@_errorMessage</pre>
                        </details>
                    }
                </div>
            }
        </section>

        @if (_result != null && _result.Success && _audioLoaded)
        {
            <section class="audio-result">
                <span class="audio-result-label">生成结果 — @_result.VoiceName · @_result.ModelName</span>
                <div class="audio-meta">
                    <span>@_audioFileName</span>
                    <span>@_audioFileSize</span>
                </div>
                <div class="audio-player">
                    <button class="play-btn" @onclick="TogglePlay">
                        @if (_isPlaying)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="14" y="4" width="4" height="16" rx="1"/><rect x="6" y="4" width="4" height="16" rx="1"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                        }
                    </button>
                    <div class="progress-area">
                        <div class="progress-time">
                            <span>@FormatTime(_currentTime)</span>
                            <span>@FormatTime(_duration)</span>
                        </div>
                        <input type="range" class="audio-slider" min="0" max="1000" value="@((int)(ProgressPercent * 10))" @oninput="OnSliderSeek" />
                    </div>
                    <div class="select-wrapper playback-speed" title="播放速度">
                        <select class="form-select" @bind="_playbackSpeedStr" @bind:after="OnPlaybackSpeedChanged">
                            <option value="0.5">0.5x</option>
                            <option value="0.75">0.75x</option>
                            <option value="1">1.0x</option>
                            <option value="1.25">1.25x</option>
                            <option value="1.5">1.5x</option>
                            <option value="2">2.0x</option>
                        </select>
                    </div>
                    <button class="download-btn" title="打开音频所在文件夹" @onclick="OpenAudioFolder">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
                    </button>
                    <button class="download-btn" title="移动音频到指定文件夹…" @onclick="MoveAudioToFolder">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </button>
                </div>
            </section>
        }
        </aside>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <div class="toast @($"toast-{_statusKind}")">@_statusMessage</div>
}

@code {
    [Parameter] public string VendorId { get; set; } = "";

    private VendorConfig? _vendor;
    private string _selectedModelId = "";
    private string _selectedVoiceId = "";
    private string _inputText = "";
    private double _speed = 1.0;
    private double _volume = 50.0;
    private bool _isGenerating = false;
    private string? _errorMessage;
    private TtsResult? _result;

    // 播放器状态
    private bool _isPlaying = false;
    private double _currentTime = 0;
    private double _duration = 0;
    private double _playbackSpeed = 1.0;
    private string _playbackSpeedStr = "1";
    private double ProgressPercent => _duration > 0 ? (_currentTime / _duration * 100) : 0;

    // 音频文件元信息
    private bool _audioLoaded = false;
    private string _audioFileName = "";
    private string _audioFileSize = "";
    private string? _statusMessage;
    private string _statusKind = "info";
    private System.Threading.CancellationTokenSource? _statusCts;

    private DotNetObjectReference<Workspace>? _dotNetRef;

    private List<VoiceOption> _allVoices = new();
    private bool _isFetchingVoices = false;
    private string _searchText = "";
    private string _filterCategory = "";
    private string _filterGender = "";
    private string _selectedVoiceName = "";
    private string _selectedEmotion = "general";
    private int _emotionIntensity = TencentEmotionPolicy.DefaultIntensity;
    private string _selectedStyle = "";
    private string _instructions = "";
    private TtsInputFormat _inputFormat = TtsInputFormat.PlainText;
    private string _outputFormat = "mp3";
    private double _styleDegree = 1.0;
    private string _ssmlText = "";
    private const int VoicePageSize = 36;
    private int _voicePageIndex = 0;
    private VoiceOption? _selectedVoice => _allVoices.FirstOrDefault(v => v.Id == _selectedVoiceId && v.Name == _selectedVoiceName);

    // 所有分类标签（去重）
    private List<string> _allCategories = new();

    // 筛选后的音色列表
    private IEnumerable<VoiceOption> FilteredVoices
    {
        get
        {
            var q = _allVoices.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(_searchText))
                q = q.Where(v => v.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                               || v.Id.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(_filterCategory))
                q = q.Where(v => IsHuoshan
                    ? HuoshanEmotionPolicy.MatchesCategory(v, _filterCategory)
                    : v.Categories.Contains(_filterCategory));
            if (!string.IsNullOrEmpty(_filterGender))
                q = q.Where(v => v.Gender == _filterGender);
            return q;
        }
    }

    private void SelectVoice(VoiceOption v)
    {
        _selectedVoiceId = v.Id;
        _selectedVoiceName = v.Name;
        if (IsHuoshan)
        {
            var resourceId = HuoshanEmotionPolicy.GetResourceId(v);
            if (!string.IsNullOrWhiteSpace(resourceId) && _vendor?.DefaultModels.Any(m => m.Id == resourceId) == true)
                _selectedModelId = resourceId;

            var emotionOptions = GetHuoshanEmotionOptions(v).ToList();
            _selectedEmotion = emotionOptions.Any(e => e.Id == "neutral") ? "neutral"
                             : emotionOptions.FirstOrDefault()?.Id ?? "";
        }
        else if (IsTencent)
        {
            _selectedEmotion = "";
            _emotionIntensity = TencentEmotionPolicy.DefaultIntensity;
        }
        else if (IsCartesia)
        {
            _selectedEmotion = "neutral";
        }
        else
        {
            _selectedEmotion = "";
        }

        if (IsAzure && !AzureStyleOptions.Any(style => style.Id == _selectedStyle))
            _selectedStyle = "";
