<Window x:Class="VoiceServiceDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:components="clr-namespace:VoiceServiceDemo.Components"
        Title="语音测试工作台"
        Width="1440"
        Height="900"
        MinWidth="1024"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A">
    <Grid>
        <blazor:BlazorWebView x:Name="BlazorWebView"
                              HostPage="wwwroot/index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app"
                                      ComponentType="{x:Type components:App}" />
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>
