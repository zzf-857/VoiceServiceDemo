# 火山引擎 TTS API 密钥
# 生成语音格式: AppID|AccessToken
# V3 + 全量音色库高级格式: AppID|AccessToken|Cluster|AK|SK|V3ApiKey|ResourceId
# ResourceId 默认 seed-tts-2.0；只用 AppID/AccessToken 也会优先走 V3，失败时回退旧版 v1
# 示例: 123456|your_token
HUOSHAN_API_KEY=

# OpenAI TTS API 密钥
OPENAI_API_KEY=

# 阿里云 API 密钥
ALIYUN_API_KEY=

# 百度 API 密钥（格式: api_key|secret_key）
BAIDU_API_KEY=

# Azure API 密钥（格式: subscription_key|region）
AZURE_API_KEY=

# Google API 密钥
GOOGLE_API_KEY=

# 服务器端口（默认 5000）
PORT=5000

# 音频输出目录（默认 ./output）
OUTPUT_DIR=./output
