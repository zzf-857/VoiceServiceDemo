# 测试用环境变量文件
# 注意：这是示例文件，请勿在生产环境使用

# 火山引擎（格式: AppID|AccessToken|Cluster|AK|SK）
# 示例格式，请替换为真实值
HUOSHAN_API_KEY=123456|test_token|volcano_tts|test_ak|test_sk

# OpenAI
OPENAI_API_KEY=sk-test-xxxxxxxxxxxxx

# 服务器配置
PORT=5000
OUTPUT_DIR=./output

# 说明：
# 1. 复制此文件为 .env
# 2. 替换所有 test_ 开头的值为真实的 API Keys
# 3. 确保格式正确（火山引擎需要 5 个部分，用 | 分隔）
