# 测试用环境变量文件
# 注意：这是示例文件，请勿在生产环境使用

# 火山引擎（生成语音格式: AppID|AccessToken）
# V3 / 全量音色库高级格式: AppID|AccessToken|Cluster|AK|SK|V3ApiKey|ResourceId
# 示例格式，请替换为真实值
HUOSHAN_API_KEY=123456|test_token

# OpenAI
OPENAI_API_KEY=sk-test-xxxxxxxxxxxxx

# 服务器配置
PORT=5000
OUTPUT_DIR=./output

# 说明：
# 1. 复制此文件为 .env
# 2. 替换所有 test_ 开头的值为真实的 API Keys
# 3. 确保格式正确（火山引擎生成语音至少需要 AppID|AccessToken，V3 API Key 可填在第 6 段）
